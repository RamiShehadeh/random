// Assets/Editor/BuildRetryMenu.cs

using System.Diagnostics;
using System.IO;
using UnityEditor;
using UnityEngine;

public static class BuildRetryMenu
{
    // Path to shell script, relative to project root
    private const string ScriptRelativePath = "unity_build_retry.sh";

    [MenuItem("Build/Run Auto-Retry (Both Profiles)")]
    public static void RunBothProfiles()
    {
        RunScript();
    }

    [MenuItem("Build/Run Auto-Retry (Quest 3 Only)")]
    public static void RunQuest3Only()
    {
        RunScript("quest3");
    }

    [MenuItem("Build/Run Auto-Retry (Android Phone Only)")]
    public static void RunAndroidOnly()
    {
        RunScript("android");
    }

    private static void RunScript(string argument = "")
    {
        string projectRoot = Path.GetFullPath(Path.Combine(Application.dataPath, ".."));
        string scriptPath  = Path.Combine(projectRoot, ScriptRelativePath);

        if (!File.Exists(scriptPath))
        {
            Debug.LogError(
                $"[BuildRetry] Shell script not found at: {scriptPath}\n" +
                "Check ScriptRelativePath in BuildRetryMenu.cs");
            return;
        }

        SetExecutable(scriptPath);

        Debug.Log($"[BuildRetry] Launching build script{(argument != "" ? $" ({argument})" : "")}...");

#if UNITY_EDITOR_WIN
        LaunchWindows(scriptPath, argument);
#else
        LaunchMacLinux(scriptPath, argument);
#endif
    }

    private static void LaunchMacLinux(string scriptPath, string argument)
    {
#if UNITY_EDITOR_OSX
        string escapedPath = scriptPath.Replace("'", "\\'");
        string escapedArg  = argument.Replace("'", "\\'");
        string osaScript   =
            $"tell application \"Terminal\"\n" +
            $"  activate\n" +
            $"  do script \"'{escapedPath}' {escapedArg}\"\n" +
            $"end tell";

        RunProcess("osascript", $"-e '{osaScript}'");
#else
        // Linux — tries common terminal emulators in order
        string[] terminals = { "gnome-terminal", "xterm", "konsole", "xfce4-terminal" };
        string   args      = $"bash \"{scriptPath}\" {argument}";
        bool     launched  = false;

        foreach (string term in terminals)
        {
            try
            {
                RunProcess(term, $"-- bash -c \"{args}; read -p 'Press enter to close...'\"");
                launched = true;
                break;
            }
            catch { /* try next */ }
        }

        if (!launched)
        {
            Debug.LogWarning("[BuildRetry] No terminal emulator found — running silently. Check build_logs/ for output.");
            RunProcess("bash", $"\"{scriptPath}\" {argument}");
        }
#endif
    }

    private static void LaunchWindows(string scriptPath, string argument)
    {
        string gitBash = @"C:\Program Files\Git\bin\bash.exe";

        if (!File.Exists(gitBash))
        {
            Debug.LogError(
                "[BuildRetry] Git Bash not found at default path.\n" +
                "Install Git for Windows, or update 'gitBash' path in BuildRetryMenu.cs.");
            return;
        }

        string args = $"--login -i -c \"\\\"{scriptPath}\\\" {argument}; read -p 'Press enter to close...'\"";
        RunProcess("cmd.exe", $"/c start \"Unity Build Retry\" \"{gitBash}\" {args}");
    }

    private static void RunProcess(string fileName, string arguments)
    {
        var psi = new ProcessStartInfo
        {
            FileName        = fileName,
            Arguments       = arguments,
            UseShellExecute = true,
            CreateNoWindow  = false,
        };

        using var process = Process.Start(psi);
        // Intentionally not waiting — editor stays responsive
    }

    private static void SetExecutable(string path)
    {
#if !UNITY_EDITOR_WIN
        try { RunProcess("chmod", $"+x \"{path}\""); }
        catch { /* non-fatal */ }
#endif
    }
}


